{
  "enabled": true,
  "rulesDir": ".persona/rules",
  "evidenceDir": ".persona/evidence",
  "conventions": {
    "controller.repository-dependency": "block",
    "controller.persistence-import": "warn"
  },
  "enforce": {
    "executeVerification": false
